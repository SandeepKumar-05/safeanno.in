# വെള്ളം കേറിയോ? — Environment Variables
# Copy this to .env and fill in your values

# Supabase project credentials
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Web Push — generate VAPID keys with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# IMD API URL (optional — used by sync-imd-alerts edge function)
VITE_IMD_API_URL=https://imdkol.gov.in/StateDW/kerala.json

# MSG91 SMS (optional — for SMS route alerts)
# MSG91_AUTH_KEY=your-msg91-auth-key

# Supabase Edge Function secrets (set in Supabase dashboard, not here)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
